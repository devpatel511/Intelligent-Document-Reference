[Unit]
Description=Document Search API
After=network.target postgresql.service

[Service]
Type=notify
User=docsearch
Group=docsearch
WorkingDirectory=/opt/docsearch
ExecStart=/opt/docsearch/venv/bin/uvicorn app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONPATH=/opt/docsearch

[Install]
WantedBy=multi-user.target
