# ── Backend selection ─────────────────────────────────────────────────────────
DEFAULT_EMBEDDING_BACKEND=gemini
DEFAULT_INFERENCE_BACKEND=gemini

# ── Google Gemini (AI Studio) ────────────────────────────────────────────────
