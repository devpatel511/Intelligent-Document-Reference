# ── Backend selection ─────────────────────────────────────────────────────────
DEFAULT_EMBEDDING_BACKEND=gemini
DEFAULT_INFERENCE_BACKEND=gemini

# ── Google Gemini (AI Studio) ────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database paths ───────────────────────────────────────────────────────────
UNIFIED_DB_PATH=local_search.db
WATCHER_DB_PATH=file_registry.db

# ── Embedding dimension (3072 for Gemini gemini-embedding-001) ──────────────────
EMBEDDING_DIMENSION=3072

# ── OCR for images (JPG, PNG, etc.) ─────────────────────────────────────────────
# Set to false to disable. Requires: brew install tesseract && pip install pytesseract
OCR_ENABLED=true
